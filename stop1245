$p = Get-CimInstance Win32_Process -Filter "Name='node.exe'" | Select-Object ProcessId, CreationDate, CommandLine; if ($p) { $p | Format-List } else { "no node.exe processes" }; "---- cloudflared ----"; $c = Get-CimInstance Win32_Process -Filter "Name='cloudflared.exe'" | Select-Object ProcessId, CreationDate; if ($c) { $c | Format-Table -AutoSize } else { "no cloudflared processes" }