# Copy this file to ".env" and fill in your own values. Never commit the real .env.

# ===== Discord (required) =====
DISCORD_TOKEN=your-bot-token-here
CLIENT_ID=your-application-id-here
# Optional: a single guild ID for instant command registration (blank = global)
GUILD_ID=

# ===== Google Gemini (the "Talk to AI" feature) =====
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ===== Economy roles =====
PROTECTED_ROLE_ID=
BUCK_ROLE_NAME=Buck

# ===== Web dashboard =====
WEB_ENABLED=true
WEB_PORT=3000
OAUTH_CLIENT_SECRET=
OAUTH_REDIRECT_URI=http://localhost:3000/callback
# Public base URL of the dashboard (used in the /verify DM link). Your tunnel or domain, no trailing slash.
PUBLIC_URL=
SESSION_SECRET=change-me-to-a-long-random-string
# Comma-separated Discord user IDs treated as owners
OWNER_IDS=
# Comma-separated Google emails treated as owners
OWNER_EMAILS=

# ===== Google Sign-In =====
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# ===== Cloudflare Turnstile (optional bot check) =====
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ===== OpenWeather (the /weather command) =====
OPENWEATHER_API_KEY=

# ===== Optional scale-out =====
DATABASE_URL=
REDIS_URL=

# ===== ER:LC (Roblox) integration =====
ERLC_API_KEY=
